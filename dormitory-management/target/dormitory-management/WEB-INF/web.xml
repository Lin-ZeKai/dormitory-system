<?xml version="1.0" encoding="UTF-8"?>
<!--
  Web 应用部署描述文件
  配置欢迎页、Filter 过滤器链。
  Servlet 通过 @WebServlet 注解注册，无需在此重复配置。
  Filter 执行顺序：EncodingFilter → LoginFilter（按声明顺序）
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>宿舍考勤与管理系统</display-name>

    <!-- 默认首页：访问项目根路径时自动打开 index.jsp -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- 静态资源 MIME 类型，确保 css 以 text/css 返回，浏览器才会渲染样式 -->
    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>
    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>

    <!-- 编码过滤器：只拦截 JSP 和 Servlet，不拦截 css/js 等静态文件 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.dormitory.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>*.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/login</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/logout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/register</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/announcements</url-pattern>
    </filter-mapping>

    <!-- 登录拦截过滤器：未登录用户无法访问受保护页面 -->
    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>com.dormitory.filter.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlet 注解配置说明 -->
    <!-- LoginServlet  -> /login   登录处理 -->
    <!-- LogoutServlet -> /logout  退出登录 -->

</web-app>
